# Anthropic API Key
API_KEY=

# Optional: override the analyze step's effort level at runtime without a redeploy.
# Values: low | medium | high | xhigh | max. Defaults to env.tsx (currently: medium).
# MODEL_EFFORT_ANALYZE=

# Clio Manage Integration
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
APP_URL=

# Storage backend — set ONE of the following groups. The app uses Cosmos DB if
# COSMOS_ENDPOINT is set; otherwise falls back to Firestore if FIREBASE_PRIVATE_KEY
# is set. Without either, the SOP and export endpoints return 503.

# Option A: Azure Cosmos DB (Azure deployments)
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=calendaring_clerk
COSMOS_CONTAINER=sop_data
COSMOS_SOP_DOC_ID=main_document

# Option B: Firebase Firestore (Google Cloud Run deployments)
# Paste the full contents of the Firebase service account JSON.
FIREBASE_PRIVATE_KEY=
